        "import pandas as pd\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.metrics import mean_absolute_error\n",
        "import joblib\n",
        "import zipfile\n",
        "import os\n",
        "\n",
        "# Load Dataset\n",
        "# The original path '/content/sample_data' caused an IsADirectoryError.\n",
        "# Assuming 'Advertising.csv' is the intended dataset, which is likely inside the provided zip file.\n",
        "# Extract 'Advertising.csv' from 'archive (9) (1).zip'\n",
        "zip_path = '/content/archive (9) (1).zip'\n",
        "output_dir = '/content/'\n",
        "\n",
        "with zipfile.ZipFile(zip_path, 'r') as zip_ref:\n",
        "    zip_ref.extract('Advertising.csv', output_dir)\n",
        "\n",
        "df = pd.read_csv(os.path.join(output_dir, 'Advertising.csv'))\n",
        "\n",
        "# Features and Target\n",
        "X = df[['TV', 'Radio', 'Newspaper']]\n",
        "y = df['Sales']\n",
        "\n",
        "# Train Model\n",
        "model = LinearRegression()\n",
        "model.fit(X, y)\n",
        "\n",
        "# Save Model\n",
        "joblib.dump(model, \"sales_model.pkl\")\n",
        "\n",
        "print(\"Model Saved Successfully\")\n",
        "\n",
        "# Load Saved Model\n",
        "model = joblib.load(\"sales_model.pkl\")\n",
        "\n",
        "# User Input Values\n",
        "tv = 230.1\n",
        "radio = 37.8\n",
        "newspaper = 69.2\n",
        "\n",
        "# Create DataFrame\n",
        "input_data = pd.DataFrame({\n",
        "    'TV': [tv],\n",
        "    'Radio': [radio],\n",
        "    'Newspaper': [newspaper]\n",
        "})\n",
        "\n",
        "# Predict Sales\n",
        "prediction = model.predict(input_data)\n",
        "\n",
        "print(\"\\nSales Prediction App\")\n",
        "print(\"--------------------\")\n",
        "print(\"TV Advertising Budget:\", tv)\n",
        "print(\"Radio Advertising Budget:\", radio)\n",
        "print(\"Newspaper Advertising Budget:\", newspaper)\n",
        "print(f\"\\nPredicted Sales = {prediction[0]:.2f}\")"
      ],
